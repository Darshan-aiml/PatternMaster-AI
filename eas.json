{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "${EXPO_PUBLIC_GOOGLE_CLIENT_ID}"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "${EXPO_PUBLIC_GOOGLE_CLIENT_ID}"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "${EXPO_PUBLIC_GOOGLE_CLIENT_ID}"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
